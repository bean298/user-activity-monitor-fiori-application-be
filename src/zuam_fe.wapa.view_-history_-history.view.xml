<mvc:View xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                          
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table" displayBlock="true" controllerName="useractivitymonitorfioriapplication.controller.history.History">                                                                                                                               
    <Page id="HistoryPage" title="{i18n>HistoryTitle}" class="sapUiLargeMarginBottom uamSubPage">                                                                                                                                                              
        <content>                                                                                                                                                                                                                                              
            <!-- FILTER -->                                                                                                                                                                                                                                    
            <HBox id="historyFilterBar" wrap="Wrap" alignItems="Start" renderType="Bare" class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom">                                                                                             
                <!-- Filter action type -->                                                                                                                                                                                                                    
                <VBox id="historyActionTypeFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                             
                    <Label id="historyActionTypeFilterLabel" text="{i18n>historyActionType}" labelFor="historyActionTypeFilter" />                                                                                                                             
                    <Select id="historyActionTypeFilter" width="13rem" change="onFilterActionType">                                                                                                                                                            
                        <core:Item id="historyActionTypeAll" key="" text="{i18n>all}" />                                                                                                                                                                       
                        <core:Item id="historyActionTypeLocked" key="LOCKED" text="{i18n>historyLocked}" />                                                                                                                                                    
                        <core:Item id="historyActionTypeUnlocked" key="UNLOCK_USER" text="{i18n>historyUnlocked}" />                                                                                                                                           
                    </Select>                                                                                                                                                                                                                                  
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Search username -->                                                                                                                                                                                                                       
                <VBox id="historyUsernameFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                               
                    <Label id="historyUsernameFilterLabel" text="{i18n>searchUser}" labelFor="historyUsernameFilter" />                                                                                                                                        
                    <Input id="historyUsernameFilter" width="13rem" showClearIcon="true" liveChange="onSearchUsername" />                                                                                                                                      
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Filter action date -->                                                                                                                                                                                                                    
                <VBox id="historyActionDateFilterBox">                                                                                                                                                                                                         
                    <Label id="historyActionDateFilterLabel" text="{i18n>historyActionDate}" labelFor="historyActionDateFilter" />                                                                                                                             
                    <DateRangeSelection id="historyActionDateFilter" width="15rem" placeholder="{i18n>historyActionDate}" displayFormat="dd-MM-yyyy" valueFormat="yyyy-MM-dd" delimiter=" - " dateValue="{globalFilterDate>/fromDate}" secondDateValue="{globa+
lFilterDate>/toDate}" change="onFilterActionDate" />                                                                                                                                                                                                           
                </VBox>                                                                                                                                                                                                                                        
            </HBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <!-- TABLE -->                                                                                                                                                                                                                                     
            <ui:Table id="HistoryTable" rows="{view>/historyRows}" selectionMode="None" alternateRowColors="true" busyIndicatorDelay="1000" visibleRowCount="10">                                                                                              
                <ui:extension>                                                                                                                                                                                                                                 
                    <OverflowToolbar id="historyTableToolbar">                                                                                                                                                                                                 
                        <Title id="historyTableTitle" text="{= ${i18n>historyList} + ' (' + ${view>/historyCount} + ')' }" level="H2" />                                                                                                                       
                    </OverflowToolbar>                                                                                                                                                                                                                         
                </ui:extension>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <ui:columns>                                                                                                                                                                                                                                   
                    <!-- History id column -->                                                                                                                                                                                                                 
                    <ui:Column id="historyIdColumn" width="15rem" sortProperty="HistoryId" tooltip="{i18n>introSort}">                                                                                                                                         
                        <Label id="historyIdLabel" text="{i18n>historyId}" />                                                                                                                                                                                  
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="historyIdText" text="{view>HistoryId}" wrapping="false" tooltip="{view>HistoryId}" />                                                                                                                                    
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- Action type column -->                                                                                                                                                                                                                
                    <ui:Column id="historyActionTypeColumn" width="9rem" sortProperty="ActionType" tooltip="{i18n>introSort}">                                                                                                                                 
                        <Label id="historyActionTypeLabel" text="{i18n>historyActionType}" />                                                                                                                                                                  
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="historyActionTypeStatus" text="{path: 'view>ActionType', formatter: '.formatter.formatHistoryAction'}" icon="{path: 'view>ActionType', formatter: '.formatter.formatHistoryActionIcon'}" state="{path: 'view>Act+
ionType', formatter: '.formatter.formatHistoryActionState'}" />                                                                                                                                                                                                
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- Username column -->                                                                                                                                                                                                                   
                    <ui:Column id="historyUsernameColumn" width="10rem" sortProperty="Username" tooltip="{i18n>introSort}">                                                                                                                                    
                        <Label id="historyUsernameLabel" text="{i18n>username}" />                                                                                                                                                                             
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="historyUsernameText" text="{view>Username}" wrapping="false" />                                                                                                                                                          
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- Action date column -->                                                                                                                                                                                                                
                    <ui:Column id="historyActionDateColumn" width="9rem" sortProperty="ActionDate" tooltip="{i18n>introSort}">                                                                                                                                 
                        <Label id="historyActionDateLabel" text="{i18n>historyActionDate}" />                                                                                                                                                                  
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="historyActionDateText" text="{path: 'view>ActionDate', formatter: '.formatter.formatISODate'}" />                                                                                                                        
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- Action time column -->                                                                                                                                                                                                                
                    <ui:Column id="historyActionTimeColumn" width="8rem" sortProperty="ActionTime" tooltip="{i18n>introSort}">                                                                                                                                 
                        <Label id="historyActionTimeLabel" text="{i18n>historyActionTime}" />                                                                                                                                                                  
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="historyActionTimeText" text="{view>ActionTime}" />                                                                                                                                                                       
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- Action message column -->                                                                                                                                                                                                             
                    <ui:Column id="historyActionMessageColumn" sortProperty="ActionMessage" tooltip="{i18n>introSort}">                                                                                                                                        
                        <Label id="historyActionMessageLabel" text="{i18n>historyActionMessage}" />                                                                                                                                                            
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="historyActionMessageText" text="{view>ActionMessage}" wrapping="false" tooltip="{view>ActionMessage}" />                                                                                                                 
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- Reason column -->                                                                                                                                                                                                                     
                    <ui:Column id="historyReasonColumn" width="14rem" sortProperty="Reason" tooltip="{i18n>introSort}">                                                                                                                                        
                        <Label id="historyReasonLabel" text="{i18n>historyReason}" />                                                                                                                                                                          
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="historyReasonText" text="{view>Reason}" wrapping="false" tooltip="{view>Reason}" />                                                                                                                                      
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <footer>                                                                                                                                                                                                                                               
            <!-- PAGINATION -->                                                                                                                                                                                                                                
            <OverflowToolbar id="historyPaginationToolbar" class="sapUiSmallMarginBottom">                                                                                                                                                                     
                <ToolbarSpacer id="historyPaginationSpacer" />                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
                <!-- Page size -->                                                                                                                                                                                                                             
                <Label id="historyPageSizeLabel" text="{i18n>rowsPerPage}" labelFor="historyPageSizeSelect" />                                                                                                                                                 
                <Select id="historyPageSizeSelect" width="5rem" selectedKey="{view>/pageSize}" change="onChangePageSize" class="sapUiTinyMarginEnd">                                                                                                           
                    <core:Item id="historyPageSize10" key="10" text="10" />                                                                                                                                                                                    
                    <core:Item id="historyPageSize20" key="20" text="20" />                                                                                                                                                                                    
                </Select>                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                <!-- Page navigation -->                                                                                                                                                                                                                       
                <Button id="historyFirstPageButton" icon="sap-icon://media-rewind" type="Transparent" tooltip="{i18n>firstPage}" enabled="{view>/canGoPrevious}" press="onFirstPage" />                                                                        
                <Button id="historyPreviousPageButton" icon="sap-icon://navigation-left-arrow" type="Transparent" tooltip="{i18n>previousPage}" enabled="{view>/canGoPrevious}" press="onPreviousPage" />                                                      
                <Text id="historyPageInfoText" text="{= ${i18n>page} + ' ' + ${view>/currentPage} + ' / ' + ${view>/totalPages} }" class="sapUiTinyMarginBeginEnd" />                                                                                          
                <Button id="historyNextPageButton" icon="sap-icon://navigation-right-arrow" type="Transparent" tooltip="{i18n>nextPage}" enabled="{view>/canGoNext}" press="onNextPage" />                                                                     
                <Button id="historyLastPageButton" icon="sap-icon://media-forward" type="Transparent" tooltip="{i18n>lastPage}" enabled="{view>/canGoNext}" press="onLastPage" />                                                                              
                                                                                                                                                                                                                                                               
                <ToolbarSeparator id="historyPaginationSeparator" />                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                <!-- Record range -->                                                                                                                                                                                                                          
                <Text id="historyRecordRangeText" text="{= ${i18n>showingRecords} + ' ' + ${view>/displayFrom} + ' - ' + ${view>/displayTo} + ' ' + ${i18n>ofRecords} + ' ' + ${view>/historyCount} }" />                                                      
            </OverflowToolbar>                                                                                                                                                                                                                                 
        </footer>                                                                                                                                                                                                                                              
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               