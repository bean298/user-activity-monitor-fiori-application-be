<core:FragmentDefinition xmlns:core="sap.ui.core"                                                                                                                                                                                                              
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table">                                                                                                                                                                                                                                   
    <Dialog id="activityUserSearchHelpDialog" title="{i18n>userSearchHelpTitle}" contentWidth="20%" contentHeight="50%" draggable="true" resizable="true">                                                                                                     
        <VBox id="activityUserSearchHelpContent" fitContainer="true" class="sapUiSmallMargin">                                                                                                                                                                 
            <SearchField id="activityUserHelpSearchField" width="100%" placeholder="{i18n>searchUser}" liveChange=".onUserHelpSearch" search=".onUserHelpSearch" class="sapUiSmallMarginBottom" />                                                             
                                                                                                                                                                                                                                                               
            <ui:Table id="activityUserHelpTable" rows="{userSearchHelp>/}" visibleRowCount="10" selectionMode="Single" selectionBehavior="Row" alternateRowColors="true" busyIndicatorDelay="1000">                                                            
                <ui:columns>                                                                                                                                                                                                                                   
                    <ui:Column id="activityUserHelpUsernameColumn" width="16rem" sortProperty="Username">                                                                                                                                                      
                        <Label id="activityUserHelpUsernameLabel" text="{i18n>username}" />                                                                                                                                                                    
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activityUserHelpUsernameText" text="{userSearchHelp>Username}" wrapping="false" />                                                                                                                                       
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </VBox>                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="activityUserSearchHelpConfirmBtn" text="{i18n>select}" type="Emphasized" press=".onUserHelpConfirm" />                                                                                                                                 
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="activityUserSearchHelpCancelBtn" text="{i18n>cancel}" press=".onUserHelpCancel" />                                                                                                                                                     
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     