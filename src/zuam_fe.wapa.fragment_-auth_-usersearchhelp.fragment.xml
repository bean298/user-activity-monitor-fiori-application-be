<core:FragmentDefinition xmlns:core="sap.ui.core"                                                                                                                                                                                                              
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table">                                                                                                                                                                                                                                   
    <Dialog id="userSearchHelpDialog" title="{i18n>userSearchHelpTitle}" contentWidth="20%" contentHeight="50%" draggable="true" resizable="true">                                                                                                             
        <VBox id="userSearchHelpContent" fitContainer="true" class="sapUiSmallMargin">                                                                                                                                                                         
            <SearchField id="userSearchHelpSearchField" width="100%" placeholder="{i18n>searchUser}" liveChange=".onUserHelpSearch" search=".onUserHelpSearch" class="sapUiSmallMarginBottom" />                                                               
                                                                                                                                                                                                                                                               
            <ui:Table id="userHelpTable" rows="{userSearchHelp>/}" visibleRowCount="10" selectionMode="Single" selectionBehavior="Row" alternateRowColors="true" busyIndicatorDelay="1000">                                                                    
                <ui:columns>                                                                                                                                                                                                                                   
                    <ui:Column id="userHelpUsernameColumn" width="16rem" sortProperty="Username">                                                                                                                                                              
                        <Label id="userHelpUsernameLabel" text="{i18n>username}" />                                                                                                                                                                            
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="userHelpUsernameText" text="{userSearchHelp>Username}" wrapping="false" />                                                                                                                                               
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </VBox>                                                                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                               
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="userSearchHelpConfirmButton" text="{i18n>select}" type="Emphasized" press=".onUserHelpConfirm" />                                                                                                                                      
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="userSearchHelpCancelButton" text="{i18n>cancel}" press=".onUserHelpCancel" />                                                                                                                                                          
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               