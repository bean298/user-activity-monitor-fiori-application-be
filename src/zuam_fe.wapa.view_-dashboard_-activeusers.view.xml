<mvc:View controllerName="useractivitymonitorfioriapplication.controller.dashboard.ActiveUsers"                                                                                                                                                                
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:ui="sap.ui.table" displayBlock="true">                                                                                                                                                                                                               
    <Page id="activeUsersPage" title="{i18n>activeUsersTitle}" class="sapUiLargeMarginBottom">                                                                                                                                                                 
        <content>                                                                                                                                                                                                                                              
            <!-- TABLE -->                                                                                                                                                                                                                                     
            <ui:Table id="activeUsersTable" rows="{view>/rows}" selectionMode="None" alternateRowColors="true" busyIndicatorDelay="0" visibleRowCount="10" class="sapUiSmallMargin">                                                                           
                <ui:extension>                                                                                                                                                                                                                                 
                    <OverflowToolbar id="activeUsersToolbar">                                                                                                                                                                                                  
                        <Title id="activeUsersTableTitle" text="{= ${i18n>activeUsersList} + ' (' + ${view>/count} + ')' }" level="H2"/>                                                                                                                       
                    </OverflowToolbar>                                                                                                                                                                                                                         
                </ui:extension>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <ui:columns>                                                                                                                                                                                                                                   
                    <!-- SESSION ID COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="activeUsersSessionColumn" width="10rem" sortProperty="SessionId">                                                                                                                                                           
                        <Label id="activeUsersSessionLabel" text="{i18n>sessionId}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersSessionText" text="{view>SessionId}" wrapping="false" tooltip="{view>SessionId}"/>                                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- USERNAME COLUMN -->                                                                                                                                                                                                                   
                    <ui:Column id="activeUsersUsernameColumn" width="8rem" sortProperty="Username">                                                                                                                                                            
                        <Label id="activeUsersUsernameLabel" text="{i18n>username}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <HBox id="activeUsersUsernameBox" alignItems="Center" renderType="Bare">                                                                                                                                                           
                                <core:Icon id="activeUsersUsernameIcon" src="sap-icon://employee" size="0.9rem" class="sapUiTinyMarginEnd"/>                                                                                                                   
                                <Text id="activeUsersUsernameText" text="{view>Username}" wrapping="false"/>                                                                                                                                                   
                            </HBox>                                                                                                                                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- FULL NAME COLUMN -->                                                                                                                                                                                                                  
                    <ui:Column id="activeUsersFullNameColumn" width="12rem" sortProperty="FullName">                                                                                                                                                           
                        <Label id="activeUsersFullNameLabel" text="{i18n>fullName}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersFullNameText" text="{view>FullName}" wrapping="false" tooltip="{view>FullName}"/>                                                                                                                             
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- EMAIL COLUMN -->                                                                                                                                                                                                                      
                    <ui:Column id="activeUsersEmailColumn" width="14rem" sortProperty="EmailAddress">                                                                                                                                                          
                        <Label id="activeUsersEmailLabel" text="{i18n>emailAddress}"/>                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersEmailText" text="{view>EmailAddress}" wrapping="false" tooltip="{view>EmailAddress}"/>                                                                                                                        
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- LOGIN DATE COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="activeUsersLoginDateColumn" width="8rem" sortProperty="LoginDate">                                                                                                                                                          
                        <Label id="activeUsersLoginDateLabel" text="{i18n>loginDate}"/>                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersLoginDateText" text="{path:'view>LoginDate', formatter: '.formatter.formatISODate'}"/>                                                                                                                        
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- LOGIN TIME COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="activeUsersLoginTimeColumn" width="8rem" sortProperty="LoginTime">                                                                                                                                                          
                        <Label id="activeUsersLoginTimeLabel" text="{i18n>loginTime}"/>                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersLoginTimeText" text="{view>LoginTime}"/>                                                                                                                                                                      
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- CLIENT COLUMN -->                                                                                                                                                                                                                     
                    <ui:Column id="activeUsersClientColumn" width="6rem">                                                                                                                                                                                      
                        <Label id="activeUsersClientLabel" text="{i18n>client}"/>                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersClientText" text="{view>UserClient}"/>                                                                                                                                                                        
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- TERMINAL COLUMN -->                                                                                                                                                                                                                   
                    <ui:Column id="activeUsersTerminalColumn" width="12rem" sortProperty="TerminalId">                                                                                                                                                         
                        <Label id="activeUsersTerminalLabel" text="{i18n>terminalId}"/>                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="activeUsersTerminalText" text="{view>TerminalId}" wrapping="false"/>                                                                                                                                                     
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- NAVIGATOR COLUMN -->                                                                                                                                                                                                                  
                    <ui:Column id="columnNavigatorActivePage" width="4rem" hAlign="Center">                                                                                                                                                                    
                        <ui:template>                                                                                                                                                                                                                          
                            <Button id="btnNavigatorActivePage" tooltip="{i18n>navigateAuth}" icon="sap-icon://navigation-right-arrow" type="Transparent" press="onPressNavigate" />                                                                           
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               