<mvc:View controllerName="useractivitymonitorfioriapplication.controller.dashboard.LockedUsers"                                                                                                                                                                
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:ui="sap.ui.table" displayBlock="true">                                                                                                                                                                                                               
    <Page id="lockedUsersPage" title="{i18n>lockedUsersTitle}" class="sapUiLargeMarginBottom">                                                                                                                                                                 
        <content>                                                                                                                                                                                                                                              
            <!-- TABLE -->                                                                                                                                                                                                                                     
            <ui:Table id="lockedUsersTable" rows="{view>/rows}" selectionMode="None" alternateRowColors="true" busyIndicatorDelay="0" visibleRowCount="10" class="sapUiSmallMargin">                                                                           
                <ui:extension>                                                                                                                                                                                                                                 
                    <OverflowToolbar id="lockedUsersToolbar">                                                                                                                                                                                                  
                        <Title id="lockedUsersTableTitle" text="{= ${i18n>lockedUsersList} + ' (' + ${view>/count} + ')' }" level="H2"/>                                                                                                                       
                    </OverflowToolbar>                                                                                                                                                                                                                         
                </ui:extension>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <ui:columns>                                                                                                                                                                                                                                   
                    <!-- USERNAME COLUMN -->                                                                                                                                                                                                                   
                    <ui:Column id="lockedUsersUsernameColumn" width="8rem" sortProperty="Username">                                                                                                                                                            
                        <Label id="lockedUsersUsernameLabel" text="{i18n>username}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <HBox id="lockedUsersUsernameBox" alignItems="Center" renderType="Bare">                                                                                                                                                           
                                <core:Icon id="lockedUsersUsernameIcon" src="sap-icon://employee" size="0.9rem" class="sapUiTinyMarginEnd"/>                                                                                                                   
                                <Link id="lockedUsersUsernameText" text="{view>Username}" wrapping="false" tooltip="{i18n>userInfoDetail}" press="onPressUser" />                                                                                              
                            </HBox>                                                                                                                                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- FULL NAME COLUMN -->                                                                                                                                                                                                                  
                    <ui:Column id="lockedUsersFullNameColumn" width="12rem" sortProperty="FullName">                                                                                                                                                           
                        <Label id="lockedUsersFullNameLabel" text="{i18n>fullName}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="lockedUsersFullNameText" text="{view>FullName}" wrapping="false" tooltip="{view>FullName}"/>                                                                                                                             
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- EMAIL COLUMN -->                                                                                                                                                                                                                      
                    <ui:Column id="lockedUsersEmailColumn" width="14rem" sortProperty="EmailAddress">                                                                                                                                                          
                        <Label id="lockedUsersEmailLabel" text="{i18n>emailAddress}"/>                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="lockedUsersEmailText" text="{view>EmailAddress}" wrapping="false" tooltip="{view>EmailAddress}"/>                                                                                                                        
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- USER GROUP COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="lockedUsersGroupColumn" width="8rem" sortProperty="UserGroup">                                                                                                                                                              
                        <Label id="lockedUsersGroupLabel" text="{i18n>userGroup}"/>                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="lockedUsersGroupText" text="{view>UserGroup}" wrapping="false"/>                                                                                                                                                         
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- LOCK STATUS COLUMN -->                                                                                                                                                                                                                
                    <ui:Column id="lockedUsersStatusColumn" width="18rem" sortProperty="LockStatus">                                                                                                                                                           
                        <Label id="lockedUsersStatusLabel" text="{i18n>lockStatus}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="lockedUsersStatus" text="{path: 'view>LockStatus', formatter: '.formatter.formatLockStatus'}" state="{path: 'view>LockStatus', formatter: '.formatter.formatLockStatusState'}" icon="{path: 'view>LockStatus', f+
ormatter: '.formatter.formatLockStatusIcon'}"/>                                                                                                                                                                                                                
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- CREATED ON COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="lockedUsersCreateOnColumn" width="8rem" sortProperty="CreateOn">                                                                                                                                                            
                        <Label id="lockedUsersCreateOnLabel" text="{i18n>createOn}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="lockedUsersCreateOnText" text="{path:'view>CreateOn', formatter: '.formatter.formatISODate'}"/>                                                                                                                          
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- UNLOCK COLUMN -->                                                                                                                                                                                                                     
                    <ui:Column id="lockedUsersUnlockColumn" width="9rem" hAlign="Center">                                                                                                                                                                      
                        <Label id="lockedUsersUnlockLabel" text="{i18n>unlockUser}"/>                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Button id="lockedUsersUnlockButton" text="{i18n>unlockUser}" icon="sap-icon://unlocked" type="Accept" press=".onUnlockUser"/>                                                                                                     
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               