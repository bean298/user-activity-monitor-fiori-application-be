<mvc:View xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                          
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table" displayBlock="true" controllerName="useractivitymonitorfioriapplication.controller.user.User">                                                                                                                                     
    <Page id="UserPage" title="{i18n>UserTitle}" class="sapUiLargeMarginBottom uamSubPage">                                                                                                                                                                    
        <content>                                                                                                                                                                                                                                              
            <!-- FILTER -->                                                                                                                                                                                                                                    
            <HBox id="userFilterBar" wrap="Wrap" alignItems="Start" renderType="Bare" class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom">                                                                                                
                                                                                                                                                                                                                                                               
                <!-- Search User -->                                                                                                                                                                                                                           
                <VBox id="usernameSearchBox" class="sapUiSmallMarginEnd">                                                                                                                                                                                      
                    <Label id="usernameSearchLabel" text="{i18n>searchUser}" />                                                                                                                                                                                
                    <Input id="userSearchInput" width="13rem" showClearIcon="true" liveChange="onSearchUser" />                                                                                                                                                
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Filter Lock Status -->                                                                                                                                                                                                                    
                <VBox id="userLockStatusFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                                
                    <Label id="userLockStatusFilterLabel" text="{i18n>lockStatus}" labelFor="userLockStatusFilter" />                                                                                                                                          
                                                                                                                                                                                                                                                               
                    <Select id="userLockStatusFilter" width="13rem" change="onFilterLockStatus">                                                                                                                                                               
                        <core:Item id="userLockStatusAll" key="" text="{i18n>all}" />                                                                                                                                                                          
                        <core:Item id="userLockStatusActive" key="ACTIVE" text="{i18n>unlocked}" />                                                                                                                                                            
                        <core:Item id="userLockStatusGlobalAdmin" key="32" text="{i18n>lockStatusGlobalAdmin}" />                                                                                                                                              
                        <core:Item id="userLockStatusLocalAdmin" key="64" text="{i18n>lockStatusLocalAdmin}" />                                                                                                                                                
                        <core:Item id="userLockStatusIncorrectLogons" key="128" text="{i18n>lockStatusIncorrectLogons}" />                                                                                                                                     
                    </Select>                                                                                                                                                                                                                                  
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Filter Email -->                                                                                                                                                                                                                          
                <VBox id="userEmailFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                                     
                    <Label id="userEmailFilterLabel" text="{i18n>emailAddress}" labelFor="userEmailSearchInput" />                                                                                                                                             
                    <Input id="userEmailSearchInput" width="13rem" showClearIcon="true" liveChange="onFilterEmail" />                                                                                                                                          
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Filter Risk Level -->                                                                                                                                                                                                                     
                <VBox id="userRiskLevelFilterBox">                                                                                                                                                                                                             
                    <Label id="userRiskLevelFilterLabel" text="{i18n>riskLevel}" labelFor="userRiskLevelFilter" />                                                                                                                                             
                    <Select id="userRiskLevelFilter" width="13rem" change="onFilterRiskLevel">                                                                                                                                                                 
                        <core:Item id="userRiskLevelAll" key="" text="{i18n>all}" />                                                                                                                                                                           
                        <core:Item id="userRiskLevelNormal" key="NORMAL" text="Normal" />                                                                                                                                                                      
                        <core:Item id="userRiskLevelLow" key="LOW" text="Low" />                                                                                                                                                                               
                        <core:Item id="userRiskLevelMedium" key="MEDIUM" text="Medium" />                                                                                                                                                                      
                        <core:Item id="userRiskLevelHigh" key="HIGH" text="High" />                                                                                                                                                                            
                        <core:Item id="userRiskLevelCritical" key="CRITICAL" text="Critical" />                                                                                                                                                                
                    </Select>                                                                                                                                                                                                                                  
                </VBox>                                                                                                                                                                                                                                        
            </HBox>                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            <!-- TABLE -->                                                                                                                                                                                                                                     
            <ui:Table id="UserTable" rows="{view>/userRows}" selectionMode="None" alternateRowColors="true" busyIndicatorDelay="1000" visibleRowCount="10" rowActionCount="1" class="sapUiMediumMarginBottom">                                                 
                <ui:extension>                                                                                                                                                                                                                                 
                    <OverflowToolbar id="userTableToolbar">                                                                                                                                                                                                    
                        <Title id="userTableTitle" text="{= ${i18n>userList} + ' (' + ${view>/recordCount} + ')' }" level="H2" />                                                                                                                              
                    </OverflowToolbar>                                                                                                                                                                                                                         
                </ui:extension>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <ui:columns>                                                                                                                                                                                                                                   
                    <!-- USERNAME COLUMN -->                                                                                                                                                                                                                   
                    <ui:Column id="colUsername" width="8rem" sortProperty="Username" tooltip="{i18n>introSort}">                                                                                                                                               
                        <Label id="labelUsername" text="{i18n>username}" />                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <HBox id="hBoxUserId" alignItems="Center" renderType="Bare">                                                                                                                                                                       
                                <core:Icon id="userIconId" src="sap-icon://employee" size="0.9rem" class="sapUiTinyMarginEnd" />                                                                                                                               
                                <Link id="textUsername" text="{view>Username}" wrapping="false" tooltip="{i18n>userInfoDetail}" press="onPressUser" />                                                                                                         
                            </HBox>                                                                                                                                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- PERSON NUMBER COLUMN -->                                                                                                                                                                                                              
                    <ui:Column id="colPersnumber" width="8rem" sortProperty="Persnumber" tooltip="{i18n>introSort}">                                                                                                                                           
                        <Label id="labelPersnumber" text="{i18n>persnumber}" />                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="textPersnumber" text="{view>Persnumber}" wrapping="false" />                                                                                                                                                             
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- ADDRESS NUMBER COLUMN -->                                                                                                                                                                                                             
                    <ui:Column id="colAddrnumber" width="8rem" sortProperty="Addrnumber" tooltip="{i18n>introSort}">                                                                                                                                           
                        <Label id="labelAddrnumber" text="{i18n>addrnumber}" />                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="textAddrnumber" text="{view>Addrnumber}" wrapping="false" />                                                                                                                                                             
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- FULL NAME COLUMN -->                                                                                                                                                                                                                  
                    <ui:Column id="colFullName" width="10rem" sortProperty="FullName" tooltip="{i18n>introSort}">                                                                                                                                              
                        <Label id="labelFullName" text="{i18n>fullName}" />                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="textFullName" text="{view>FullName}" wrapping="false" />                                                                                                                                                                 
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- EMAIL COLUMN -->                                                                                                                                                                                                                      
                    <ui:Column id="colEmail" width="12rem" sortProperty="EmailAddress" tooltip="{i18n>introSort}">                                                                                                                                             
                        <Label id="labelEmail" text="{i18n>emailAddress}" />                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="textEmail" text="{view>EmailAddress}" wrapping="false" />                                                                                                                                                                
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- USER GROUP COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="colUserGroup" width="7rem" sortProperty="UserGroup" tooltip="{i18n>introSort}">                                                                                                                                             
                        <Label id="labelUserGroup" text="{i18n>userGroup}" />                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="textUserGroup" text="{view>UserGroup}" wrapping="false" />                                                                                                                                                               
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- LOCK STATUS COLUMN -->                                                                                                                                                                                                                
                    <ui:Column id="colLockStatus" width="10rem" sortProperty="LockStatus" tooltip="{i18n>introSort}">                                                                                                                                          
                        <Label id="labelLockStatus" text="{i18n>lockStatus}" />                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="statusLockStatus" text="{path: 'view>LockStatus', formatter: '.formatter.formatLockStatus'}" state="{path: 'view>LockStatus', formatter: '.formatter.formatLockStatusState'}" icon="{path: 'view>LockStatus', fo+
rmatter: '.formatter.formatLockStatusIcon'}" />                                                                                                                                                                                                                
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- RISK LEVEL COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="colRiskLevel" width="8rem" sortProperty="TotalRiskScore" tooltip="{i18n>introSort}">                                                                                                                                        
                        <Label id="labelRiskLevel" text="{i18n>riskLevel}" />                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="statusRiskLevel" text="{path: 'view>TotalRiskScore', formatter: '.formatter.formatTotalRiskText'}" state="{path: 'view>TotalRiskScore', formatter: '.formatter.formatTotalRiskState'}" icon="{path: 'view>TotalR+
iskScore', formatter: '.formatter.formatTotalRiskIcon'}" />                                                                                                                                                                                                    
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- RISK ALERT COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="colRiskAlert" width="7rem">                                                                                                                                                                                                 
                        <Label id="labelRiskAlert" text="{i18n>riskAlertSent}" />                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <core:Icon id="riskColumn" src="sap-icon://email" color="#e9730c" visible="{= !!${view>RiskAlertSent} }" size="1rem" />                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- CREATED ON COLUMN -->                                                                                                                                                                                                                 
                    <ui:Column id="colCreateOn" width="8rem" sortProperty="CreateOn" tooltip="{i18n>introSort}">                                                                                                                                               
                        <Label id="labelCreateOn" text="{i18n>createOn}" />                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="textCreateOn" text="{path: 'view>CreateOn', formatter: '.formatter.formatISODate'}" wrapping="false" />                                                                                                                  
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
                <ui:rowActionTemplate>                                                                                                                                                                                                                         
                    <ui:RowAction id="userRowAction">                                                                                                                                                                                                          
                        <ui:RowActionItem id="userRowActionItem" type="Navigation" press="onPressUser" />                                                                                                                                                      
                    </ui:RowAction>                                                                                                                                                                                                                            
                </ui:rowActionTemplate>                                                                                                                                                                                                                        
            </ui:Table>                                                                                                                                                                                                                                        
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <footer>                                                                                                                                                                                                                                               
            <!-- Pagination -->                                                                                                                                                                                                                                
            <OverflowToolbar id="userPaginationToolbar" class="sapUiSmallMarginBottom">                                                                                                                                                                        
                <ToolbarSpacer id="userPaginationToolbarSpacer" />                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                <!-- Filter rows -->                                                                                                                                                                                                                           
                <Label id="userPageSizeLabel" text="{i18n>rowsPerPage}" labelFor="userPageSizeSelect" />                                                                                                                                                       
                <Select id="userPageSizeSelect" width="5rem" selectedKey="{view>/pageSize}" change="onChangePageSize" class="sapUiTinyMarginEnd">                                                                                                              
                    <core:Item id="userPageSize10" key="10" text="10" />                                                                                                                                                                                       
                    <core:Item id="userPageSize20" key="20" text="20" />                                                                                                                                                                                       
                    <core:Item id="userPageSize30" key="30" text="30" />                                                                                                                                                                                       
                </Select>                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                <!-- Previous and First page buttons -->                                                                                                                                                                                                       
                <Button id="userFirstPageButton" icon="sap-icon://media-rewind" type="Transparent" tooltip="{i18n>firstPage}" enabled="{view>/canGoPrevious}" press="onFirstPage" />                                                                           
                <Button id="userPreviousPageButton" icon="sap-icon://navigation-left-arrow" type="Transparent" tooltip="{i18n>previousPage}" enabled="{view>/canGoPrevious}" press="onPreviousPage" />                                                         
                                                                                                                                                                                                                                                               
                <!-- Page -->                                                                                                                                                                                                                                  
                <Text id="userPageInfoText" text="{= ${i18n>page} + ' ' + ${view>/currentPage} + ' / ' + ${view>/totalPages} }" class="sapUiTinyMarginBeginEnd" />                                                                                             
                                                                                                                                                                                                                                                               
                <!-- Next and Last page buttons -->                                                                                                                                                                                                            
                <Button id="userNextPageButton" icon="sap-icon://navigation-right-arrow" type="Transparent" tooltip="{i18n>nextPage}" enabled="{view>/canGoNext}" press="onNextPage" />                                                                        
                <Button id="userLastPageButton" icon="sap-icon://media-forward" type="Transparent" tooltip="{i18n>lastPage}" enabled="{view>/canGoNext}" press="onLastPage" />                                                                                 
                                                                                                                                                                                                                                                               
                <ToolbarSeparator id="userPaginationRecordSeparator" />                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Record per page -->                                                                                                                                                                                                                       
                <Text id="userRecordRangeText" text="{= ${i18n>showingRecords} + ' ' + ${view>/displayFrom} + ' - ' + ${view>/displayTo} + ' ' + ${i18n>ofRecords} + ' ' + ${view>/recordCount} }" />                                                          
            </OverflowToolbar>                                                                                                                                                                                                                                 
        </footer>                                                                                                                                                                                                                                              
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               