sap.ui.define([], function () {                                                                                                                                                                                                                                
  "use strict";                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
  class DashboardService {                                                                                                                                                                                                                                     
    // ==================================                                                                                                                                                                                                                      
    // Call db_active_user entity                                                                                                                                                                                                                              
    // Data for Active Users dashboard card and table                                                                                                                                                                                                          
    // ==================================                                                                                                                                                                                                                      
    static async getActiveUsers(oModel, aFilters = [], iSkip = 0, iTop) {                                                                                                                                                                                      
      const oBinding = oModel.bindList("/db_active_user", undefined, undefined, aFilters, {                                                                                                                                                                    
        $count: true                                                                                                                                                                                                                                           
      });                                                                                                                                                                                                                                                      
      const aContexts = iTop ? await oBinding.requestContexts(iSkip, iTop) : await oBinding.requestContexts();                                                                                                                                                 
      const aRows = aContexts.map(oContext => oContext.getObject());                                                                                                                                                                                           
      const iCount = oBinding.getLength();                                                                                                                                                                                                                     
      oBinding.destroy();                                                                                                                                                                                                                                      
      return {                                                                                                                                                                                                                                                 
        rows: aRows,                                                                                                                                                                                                                                           
        count: iCount                                                                                                                                                                                                                                          
      };                                                                                                                                                                                                                                                       
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    // ==================================                                                                                                                                                                                                                      
    // Call db_login_result entity                                                                                                                                                                                                                             
    // Data for Login Result dashboard card                                                                                                                                                                                                                    
    // ==================================                                                                                                                                                                                                                      
    static async getLoginResultCount(oModel, aFilters) {                                                                                                                                                                                                       
      const oBinding = oModel.bindList("/db_login_result", undefined, undefined, aFilters, {                                                                                                                                                                   
        $count: true                                                                                                                                                                                                                                           
      });                                                                                                                                                                                                                                                      
      const aContexts = await oBinding.requestContexts();                                                                                                                                                                                                      
      const aRows = aContexts.map(oContext => oContext.getObject());                                                                                                                                                                                           
      const loginSuccessCount = aRows.filter(item => item.LoginResult === "SUCCESS").reduce((acc, cur) => acc + cur.LoginCount, 0);                                                                                                                            
      const loginFailCount = aRows.filter(item => item.LoginResult === "FAIL").reduce((acc, cur) => acc + cur.LoginCount, 0);                                                                                                                                  
                                                                                                                                                                                                                                                               
      // Grouby data by LoginDate for chart                                                                                                                                                                                                                    
      const chartDataByDate = {};                                                                                                                                                                                                                              
      aRows.forEach(row => {                                                                                                                                                                                                                                   
        const loginDate = row.LoginDate;                                                                                                                                                                                                                       
        const loginCount = Number(row.LoginCount || 0);                                                                                                                                                                                                        
        if (!chartDataByDate[loginDate]) {                                                                                                                                                                                                                     
          chartDataByDate[loginDate] = {                                                                                                                                                                                                                       
            LoginDate: loginDate,                                                                                                                                                                                                                              
            LoginSuccess: 0,                                                                                                                                                                                                                                   
            LoginFailed: 0                                                                                                                                                                                                                                     
          };                                                                                                                                                                                                                                                   
        }                                                                                                                                                                                                                                                      
        if (row.LoginResult === "SUCCESS") {                                                                                                                                                                                                                   
          chartDataByDate[loginDate].LoginSuccess += loginCount;                                                                                                                                                                                               
        } else if (row.LoginResult === "FAIL") {                                                                                                                                                                                                               
          chartDataByDate[loginDate].LoginFailed += loginCount;                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
      });                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
      // Convert object to array                                                                                                                                                                                                                               
      const chartData = Object.values(chartDataByDate);                                                                                                                                                                                                        
      oBinding.destroy();                                                                                                                                                                                                                                      
      return {                                                                                                                                                                                                                                                 
        loginSuccess: loginSuccessCount,                                                                                                                                                                                                                       
        loginFail: loginFailCount,                                                                                                                                                                                                                             
        aData: chartData                                                                                                                                                                                                                                       
      };                                                                                                                                                                                                                                                       
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    // ==================================                                                                                                                                                                                                                      
    // Call db_activity_by_day entity                                                                                                                                                                                                                          
    // Data for Activity dashboard - card                                                                                                                                                                                                                      
    // ==================================                                                                                                                                                                                                                      
    static async getActivityByDay(oModel, aFilters) {                                                                                                                                                                                                          
      const oBinding = oModel.bindList("/db_activity_by_day", undefined, undefined, aFilters, {                                                                                                                                                                
        $count: true                                                                                                                                                                                                                                           
      });                                                                                                                                                                                                                                                      
      const aContexts = await oBinding.requestContexts();                                                                                                                                                                                                      
      const aRows = aContexts.map(oContext => oContext.getObject());                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
      // Grouby data by ActDate for chart                                                                                                                                                                                                                      
      const chartDataByDate = {};                                                                                                                                                                                                                              
      aRows.forEach(row => {                                                                                                                                                                                                                                   
        const actDate = row.ActDate;                                                                                                                                                                                                                           
        const activityCount = Number(row.ActivityCount || 0);                                                                                                                                                                                                  
        if (!chartDataByDate[actDate]) {                                                                                                                                                                                                                       
          chartDataByDate[actDate] = {                                                                                                                                                                                                                         
            ActDate: actDate,                                                                                                                                                                                                                                  
            ActivityCount: 0                                                                                                                                                                                                                                   
          };                                                                                                                                                                                                                                                   
        }                                                                                                                                                                                                                                                      
        chartDataByDate[actDate].ActivityCount += activityCount;                                                                                                                                                                                               
      });                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
      // Convert object to array                                                                                                                                                                                                                               
      const chartData = Object.values(chartDataByDate);                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Total activity count                                                                                                                                                                                                                                  
      const iCount = chartData.reduce((acc, cur) => acc + cur.ActivityCount, 0);                                                                                                                                                                               
      oBinding.destroy();                                                                                                                                                                                                                                      
      return {                                                                                                                                                                                                                                                 
        activityCount: iCount,                                                                                                                                                                                                                                 
        aData: chartData                                                                                                                                                                                                                                       
      };                                                                                                                                                                                                                                                       
    }                                                                                                                                                                                                                                                          
  }                                                                                                                                                                                                                                                            
  return DashboardService;                                                                                                                                                                                                                                     
});                                                                                                                                                                                                                                                            
