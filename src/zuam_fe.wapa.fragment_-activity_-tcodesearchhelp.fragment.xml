<core:FragmentDefinition xmlns:core="sap.ui.core"                                                                                                                                                                                                              
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table">                                                                                                                                                                                                                                   
    <Dialog id="tcodeSearchHelpDialog" title="{i18n>tcodeSearchHelpTitle}" contentWidth="40%" contentHeight="50%" draggable="true" resizable="true">                                                                                                           
        <VBox id="tcodeSearchHelpContent" fitContainer="true" class="sapUiSmallMargin">                                                                                                                                                                        
            <SearchField id="tcodeSearchHelpSearchField" width="100%" placeholder="{i18n>tCode}" liveChange=".onTCodeHelpSearch" search=".onTCodeHelpSearch" class="sapUiSmallMarginBottom" />                                                                 
                                                                                                                                                                                                                                                               
            <ui:Table id="tcodeHelpTable" rows="{tcodeSearchHelp>/}" visibleRowCount="10" selectionMode="Single" selectionBehavior="Row" alternateRowColors="true" busyIndicatorDelay="1000">                                                                  
                <ui:columns>                                                                                                                                                                                                                                   
                    <ui:Column id="tcodeHelpCodeColumn" width="8rem" sortProperty="Tcode">                                                                                                                                                                     
                        <Label id="tcodeHelpCodeLabel" text="{i18n>tCode}" />                                                                                                                                                                                  
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="tcodeHelpCodeText" text="{tcodeSearchHelp>Tcode}" wrapping="false" />                                                                                                                                                    
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                    <ui:Column id="tcodeHelpNameColumn" width="18rem" sortProperty="TCodeName">                                                                                                                                                                
                        <Label id="tcodeHelpNameLabel" text="{i18n>tCodeName}" />                                                                                                                                                                              
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="tcodeHelpNameText" text="{tcodeSearchHelp>TCodeName}" wrapping="false" />                                                                                                                                                
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </VBox>                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="tcodeSearchHelpConfirmButton" text="{i18n>select}" type="Emphasized" press=".onTCodeHelpConfirm" />                                                                                                                                    
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="tcodeSearchHelpCancelButton" text="{i18n>cancel}" press=".onTCodeHelpCancel" />                                                                                                                                                        
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               