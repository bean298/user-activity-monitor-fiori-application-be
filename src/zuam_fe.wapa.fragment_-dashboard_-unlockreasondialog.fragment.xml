<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
    <!-- Optional reason popup before unlocking a user. -->                                                                                                                                                                                                    
    <Dialog id="unlockReasonDialog" title="{i18n>unlockReasonTitle}" contentWidth="28rem">                                                                                                                                                                     
        <content>                                                                                                                                                                                                                                              
            <VBox id="unlockReasonContent" class="sapUiSmallMargin">                                                                                                                                                                                           
                <Label id="unlockReasonLabel" text="{i18n>lockReasonLabel}" labelFor="unlockReasonTextArea" />                                                                                                                                                 
                <TextArea id="unlockReasonTextArea" width="100%" rows="4" growing="true" growingMaxLines="6" placeholder="{i18n>unlockReasonPlaceholder}" />                                                                                                   
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                               
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="confirmUnlockUserButton" text="{i18n>confirmUnlock}" type="Accept" press=".onConfirmUnlockUser" />                                                                                                                                     
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="cancelUnlockUserButton" text="{i18n>cancel}" press=".onCancelUnlockUser" />                                                                                                                                                            
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               