<mvc:View xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                          
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table" displayBlock="true" controllerName="useractivitymonitorfioriapplication.controller.activity.Activity">                                                                                                                             
    <Page id="ActivityPage" title="{i18n>activityLog}" class="sapUiLargeMarginBottom uamSubPage">                                                                                                                                                              
        <content>                                                                                                                                                                                                                                              
            <!-- FILTER -->                                                                                                                                                                                                                                    
            <HBox id="activityFilterBar" wrap="Wrap" alignItems="Start" renderType="Bare" class="sapUiSmallMarginBegin sapUiSmallMarginTop sapUiSmallMarginBottom">                                                                                            
                <!-- Activity Type -->                                                                                                                                                                                                                         
                <VBox id="activityTypeFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                                  
                    <Label id="ActivityTypeLabel" text="{i18n>activityType}" />                                                                                                                                                                                
                    <Select id="activityTypeFilter" width="11rem" change="onFilterActivity">                                                                                                                                                                   
                        <core:Item id="itemAll" key="" text="{i18n>itemAll}" />                                                                                                                                                                                
                        <core:Item id="itemTcode" key="TCODE" text="{i18n>itemTcode}" />                                                                                                                                                                       
                        <core:Item id="itemDump" key="DUMP" text="{i18n>itemDump}" />                                                                                                                                                                          
                    </Select>                                                                                                                                                                                                                                  
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Username Search -->                                                                                                                                                                                                                       
                <VBox id="activityUsernameFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                              
                    <Label id="activityUsernameLabel" text="{i18n>searchUser}" />                                                                                                                                                                              
                    <Input id="activityUsernameFilter" value="{view>/usernameFilter}" width="14rem" showValueHelp="true" showClearIcon="true" liveChange="onSearchUserName" valueHelpRequest="onUserSearchHelp" />                                             
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- TCode Search -->                                                                                                                                                                                                                          
                <VBox id="activityTCodeFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                                 
                    <Label id="activityTCodeLabel" text="{i18n>tcodeSearchHelp}" />                                                                                                                                                                            
                    <Input id="activityTCodeFilter" value="{view>/tcodeFilter}" width="14rem" showValueHelp="true" showClearIcon="true" liveChange="onSearchTCode" valueHelpRequest="onTCodeSearchHelp" />                                                     
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Activity Date -->                                                                                                                                                                                                                         
                <VBox id="activityDateFilterBox" class="sapUiSmallMarginEnd">                                                                                                                                                                                  
                    <Label id="activityDateLabel" text="{i18n>activityDate}" />                                                                                                                                                                                
                    <DateRangeSelection id="activityDateRange" width="15rem" placeholder="{i18n>activityDateRange}" displayFormat="dd-MM-yyyy" valueFormat="yyyy-MM-dd" delimiter=" - " change="onFilterDate" dateValue="{globalFilterDate>/fromDate}" secondD+
ateValue="{globalFilterDate>/toDate}" />                                                                                                                                                                                                                       
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                <!-- Activity Time -->                                                                                                                                                                                                                         
                <VBox id="activityTimeFilterBox">                                                                                                                                                                                                              
                    <Label id="activityTimeLabel" text="{i18n>activityTime}" />                                                                                                                                                                                
                    <HBox id="activityTimeRangeBox" alignItems="Center">                                                                                                                                                                                       
                        <TimePicker id="activityTimeFrom" width="8rem" placeholder="{i18n>activityTimeFrom}" displayFormat="HH:mm:ss" valueFormat="HH:mm:ss" change="onFilterTime" />                                                                          
                                                                                                                                                                                                                                                               
                        <Text id="activityTimeRangeSeparator" text="-" class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />                                                                                                                                      
                                                                                                                                                                                                                                                               
                        <TimePicker id="activityTimeTo" width="8rem" placeholder="{i18n>activityTimeTo}" displayFormat="HH:mm:ss" valueFormat="HH:mm:ss" change="onFilterTime" />                                                                              
                    </HBox>                                                                                                                                                                                                                                    
                </VBox>                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            </HBox>                                                                                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            <!-- TABLE -->                                                                                                                                                                                                                                     
            <ui:Table id="ActivityTable" rows="{view>/activityRows}" selectionMode="None" alternateRowColors="true" busyIndicatorDelay="1000" visibleRowCount="10" class="sapUiMediumMarginBottom">                                                            
                <ui:extension>                                                                                                                                                                                                                                 
                    <OverflowToolbar id="ActivityTableToolbar">                                                                                                                                                                                                
                        <Title id="ActivityTitle" text="{= ${i18n>activityLog} + ' (' + ${view>/activityCount} + ')' }" level="H2" />                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ToolbarSpacer id="ActivityTableSpacer" />                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                        <Button id="btnExportActivity" icon="sap-icon://excel-attachment" tooltip="Export Excel" press="onExportActivityExcel" />                                                                                                              
                    </OverflowToolbar>                                                                                                                                                                                                                         
                </ui:extension>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <ui:columns>                                                                                                                                                                                                                                   
                    <!-- LOG ID -->                                                                                                                                                                                                                            
                    <ui:Column id="ColumnLogId" width="8rem" sortProperty="ActId" tooltip="{i18n>introSort}">                                                                                                                                                  
                        <Label id="LabelLogId" text="{i18n>logId}" />                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="TextLogId" text="{view>ActId}" wrapping="false" />                                                                                                                                                                       
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- USERNAME -->                                                                                                                                                                                                                          
                    <ui:Column id="ColumnUsernameId" width="8rem" sortProperty="Username" tooltip="{i18n>introSort}">                                                                                                                                          
                        <Label id="LabelUsername" text="{i18n>username}" />                                                                                                                                                                                    
                        <ui:template>                                                                                                                                                                                                                          
                            <HBox id="hBoxActivityUser" alignItems="Center" renderType="Bare">                                                                                                                                                                 
                                <core:Icon id="activityUserIcon" src="sap-icon://employee" size="0.9rem" class="sapUiTinyMarginEnd" />                                                                                                                         
                                <Link id="TextUsername" text="{view>Username}" wrapping="false" tooltip="{i18n>userInfoDetail}" press="onPressUser" />                                                                                                         
                            </HBox>                                                                                                                                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <!-- ACTIVITY TYPE -->                                                                                                                                                                                                                     
                    <ui:Column id="ColumnActivityTypeId" width="8rem" sortProperty="ActType" tooltip="{i18n>introSort}">                                                                                                                                       
                        <Label id="LabelActivityType" text="{i18n>activityType}" />                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="ObjectStatusActivityType" text="{view>ActType}" icon="{path:'view>ActType', formatter: '.formatter.formatActivityType'}" state="{path:'view>ActType', formatter: '.formatter.formatActivityState'}" />           
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- TCODE -->                                                                                                                                                                                                                             
                    <ui:Column id="ColumnTCodeId" width="6rem" sortProperty="Tcode" tooltip="{i18n>introSort}">                                                                                                                                                
                        <Label id="LabelTCode" text="{i18n>tCode}" />                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="ObjectStatusTCode" text="{view>Tcode}" icon="{path:'view>Tcode', formatter: '.formatter.formatTCodeIcon'}" />                                                                                                    
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- TCODE NAME -->                                                                                                                                                                                                                        
                    <ui:Column id="ColumnTCodeNameId" width="8rem" sortProperty="TCodeName" tooltip="{i18n>introSort}">                                                                                                                                        
                        <Label id="LabelTCodeName" text="{i18n>tCodeName}" />                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="TextTCodeName" text="{view>TCodeName}" wrapping="false" />                                                                                                                                                               
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- ACTIVITY MESSAGE -->                                                                                                                                                                                                                  
                    <ui:Column id="ColumnMsgId" sortProperty="MessageText" tooltip="{i18n>introSort}">                                                                                                                                                         
                        <Label id="LabelActivityMessage" text="{i18n>activityMessage}" />                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="StatusActivityMessage" text="{view>MessageText}" state="Information" />                                                                                                                                          
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- RISK SCORE -->                                                                                                                                                                                                                        
                    <ui:Column id="ColumnRiskScoreId" width="8rem" sortProperty="Severity" tooltip="{i18n>introSort}">                                                                                                                                         
                        <Label id="LabelRiskScore" text="{i18n>severity}" />                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <ObjectStatus id="StatusRiskScore" text="{path: 'view>Severity', formatter: '.formatter.formatSeverityText'}" state="{path: 'view>Severity', formatter: '.formatter.formatSeverityState'}" icon="{path: 'view>Severity', formatter+
: '.formatter.formatSeverityIcon'}" />                                                                                                                                                                                                                         
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- ACTIVITY DATE -->                                                                                                                                                                                                                     
                    <ui:Column id="ColumnDateId" width="8rem" sortProperty="ActDate" tooltip="{i18n>introSort}">                                                                                                                                               
                        <Label id="LabelActivityDate" text="{i18n>activityDate}" />                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="TextActivityDate" text="{path:'view>ActDate', formatter: '.formatter.formatISODate'}" />                                                                                                                                 
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    <!-- ACTIVITY TIME -->                                                                                                                                                                                                                     
                    <ui:Column id="ColumnTimeId" width="8rem" sortProperty="ActTims" tooltip="{i18n>introSort}">                                                                                                                                               
                        <Label id="LabelActivityTime" text="{i18n>activityTime}" />                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="TextActivityTime" text="{view>ActTims}" wrapping="false" />                                                                                                                                                              
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </content>                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
        <footer>                                                                                                                                                                                                                                               
            <!-- PAGINATION -->                                                                                                                                                                                                                                
            <OverflowToolbar id="activityPaginationToolbar" class="sapUiSmallMarginBottom">                                                                                                                                                                    
                <ToolbarSpacer id="activityPaginationSpacer" />                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <!-- Page size -->                                                                                                                                                                                                                             
                <Label id="activityPageSizeLabel" text="{i18n>rowsPerPage}" />                                                                                                                                                                                 
                <Select id="activityPageSizeSelect" width="5rem" selectedKey="{view>/pageSize}" change="onChangePageSize" class="sapUiTinyMarginEnd">                                                                                                          
                    <core:Item id="activityPageSize10" key="10" text="10" />                                                                                                                                                                                   
                    <core:Item id="activityPageSize20" key="20" text="20" />                                                                                                                                                                                   
                </Select>                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                <!-- Navigation buttons -->                                                                                                                                                                                                                    
                <Button id="activityFirstPageBtn" icon="sap-icon://media-rewind" type="Transparent" tooltip="{i18n>firstPage}" enabled="{view>/canGoPrevious}" press="onFirstPage" />                                                                          
                <Button id="activityPreviousPageBtn" icon="sap-icon://navigation-left-arrow" type="Transparent" tooltip="{i18n>previousPage}" enabled="{view>/canGoPrevious}" press="onPreviousPage" />                                                        
                                                                                                                                                                                                                                                               
                <!-- Page info -->                                                                                                                                                                                                                             
                <Text id="activityPageInfoText" text="{= ${i18n>page} + ' ' + ${view>/currentPage} + ' / ' + ${view>/totalPages} }" class="sapUiTinyMarginBeginEnd" />                                                                                         
                                                                                                                                                                                                                                                               
                <Button id="activityNextPageBtn" icon="sap-icon://navigation-right-arrow" type="Transparent" tooltip="{i18n>nextPage}" enabled="{view>/canGoNext}" press="onNextPage" />                                                                       
                <Button id="activityLastPageBtn" icon="sap-icon://media-forward" type="Transparent" tooltip="{i18n>lastPage}" enabled="{view>/canGoNext}" press="onLastPage" />                                                                                
                                                                                                                                                                                                                                                               
                <ToolbarSeparator id="activityPaginationSeparator" />                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                <!-- Record info -->                                                                                                                                                                                                                           
                <Text id="activityRecordRangeText" text="{= ${i18n>showingRecords} + ' ' + ${view>/displayFrom} + ' - ' + ${view>/displayTo} + ' ' + ${i18n>ofRecords} + ' ' + ${view>/activityCount} }" />                                                    
            </OverflowToolbar>                                                                                                                                                                                                                                 
        </footer>                                                                                                                                                                                                                                              
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               