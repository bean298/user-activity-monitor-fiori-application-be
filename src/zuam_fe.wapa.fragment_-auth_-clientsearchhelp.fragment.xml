<core:FragmentDefinition xmlns:core="sap.ui.core"                                                                                                                                                                                                              
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table">                                                                                                                                                                                                                                   
    <Dialog id="clientSearchHelpDialog" title="{i18n>clientSearchHelpTitle}" contentWidth="24rem" contentHeight="50%" draggable="true" resizable="true">                                                                                                       
        <VBox id="clientSearchHelpContent" fitContainer="true" class="sapUiSmallMargin">                                                                                                                                                                       
            <SearchField id="clientSearchHelpSearchField" width="100%" placeholder="{i18n>client}" liveChange=".onClientHelpSearch" search=".onClientHelpSearch" class="sapUiSmallMarginBottom" />                                                             
                                                                                                                                                                                                                                                               
            <ui:Table id="clientHelpTable" rows="{clientSearchHelp>/}" visibleRowCount="10" selectionMode="Single" selectionBehavior="Row" alternateRowColors="true" busyIndicatorDelay="1000">                                                                
                <ui:columns>                                                                                                                                                                                                                                   
                    <ui:Column id="clientHelpClientColumn" width="10rem" sortProperty="userCient">                                                                                                                                                             
                        <Label id="clientHelpClientLabel" text="{i18n>client}" />                                                                                                                                                                              
                        <ui:template>                                                                                                                                                                                                                          
                            <Text id="clientHelpClientText" text="{clientSearchHelp>userCient}" wrapping="false" />                                                                                                                                            
                        </ui:template>                                                                                                                                                                                                                         
                    </ui:Column>                                                                                                                                                                                                                               
                </ui:columns>                                                                                                                                                                                                                                  
            </ui:Table>                                                                                                                                                                                                                                        
        </VBox>                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="clientSearchHelpConfirmButton" text="{i18n>select}" type="Emphasized" press=".onClientHelpConfirm" />                                                                                                                                  
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="clientSearchHelpCancelButton" text="{i18n>cancel}" press=".onClientHelpCancel" />                                                                                                                                                      
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               