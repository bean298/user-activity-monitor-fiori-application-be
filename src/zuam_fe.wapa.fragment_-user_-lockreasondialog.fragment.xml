<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
    <!-- Optional reason popup before locking a user. -->                                                                                                                                                                                                      
    <Dialog id="lockReasonDialog" title="{i18n>lockReasonTitle}" contentWidth="28rem">                                                                                                                                                                         
        <content>                                                                                                                                                                                                                                              
            <VBox id="lockReasonContent" class="sapUiSmallMargin">                                                                                                                                                                                             
                <Label id="lockReasonLabel" text="{i18n>lockReasonLabel}" labelFor="lockReasonTextArea" />                                                                                                                                                     
                <TextArea id="lockReasonTextArea" width="100%" rows="4" growing="true" growingMaxLines="6" placeholder="{i18n>lockReasonPlaceholder}" />                                                                                                       
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="confirmLockUserButton" text="{i18n>confirmLock}" type="Reject" press=".onConfirmLockUser" />                                                                                                                                           
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="cancelLockUserButton" text="{i18n>cancel}" press=".onCancelLockUser" />                                                                                                                                                                
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               