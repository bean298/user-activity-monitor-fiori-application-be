              width: 20                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "Activity Type",                                                                                                                                                                                                                          
              property: "ActType",                                                                                                                                                                                                                             
              width: 15                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "TCode",                                                                                                                                                                                                                                  
              property: "Tcode",                                                                                                                                                                                                                               
              width: 10                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "TCode Name",                                                                                                                                                                                                                             
              property: "TCodeName",                                                                                                                                                                                                                           
              width: 20                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "Message",                                                                                                                                                                                                                                
              property: "MessageText",                                                                                                                                                                                                                         
              width: 40                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "Date",                                                                                                                                                                                                                                   
              property: "ActDate",                                                                                                                                                                                                                             
              width: 15                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "Time",                                                                                                                                                                                                                                   
              property: "ActTims",                                                                                                                                                                                                                             
              width: 15                                                                                                                                                                                                                                        
            }, {                                                                                                                                                                                                                                               
              label: "Mail Sent",                                                                                                                                                                                                                              
              property: "MailSent",                                                                                                                                                                                                                            
              width: 10                                                                                                                                                                                                                                        
            }];                                                                                                                                                                                                                                                
            const oSheet = new Spreadsheet({                                                                                                                                                                                                                   
              workbook: {                                                                                                                                                                                                                                      
                columns: aCols                                                                                                                                                                                                                                 
              },                                                                                                                                                                                                                                               
              dataSource: aData,                                                                                                                                                                                                                               
              fileName: "ActivityLogs.xlsx",                                                                                                                                                                                                                   
              worker: false                                                                                                                                                                                                                                    
            });                                                                                                                                                                                                                                                
            oSheet.build().then(() => MessageToast.show(`Export successful! (${aData.length} records)`)).catch(() => this.showError("Export failed.")).finally(() => oSheet.destroy());                                                                        
          } catch (error) {                                                                                                                                                                                                                                    
            this.showError("Failed to load data for export.");                                                                                                                                                                                                 
          } finally {                                                                                                                                                                                                                                          
            oView?.setBusy(false);                                                                                                                                                                                                                             
          }                                                                                                                                                                                                                                                    
        }                                                                                                                                                                                                                                                      
      });                                                                                                                                                                                                                                                      
