          const oView = this.getView();                                                                                                                                                                                                                        
          oView?.setBusy(true);                                                                                                                                                                                                                                
          try {                                                                                                                                                                                                                                                
            let aData = [];                                                                                                                                                                                                                                    
            if (oAction === "All Data") {                                                                                                                                                                                                                      
              const oODataModel = this.getView()?.getModel();                                                                                                                                                                                                  
