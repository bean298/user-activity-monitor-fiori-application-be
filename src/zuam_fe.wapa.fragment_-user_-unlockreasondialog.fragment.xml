<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core">                                                                                                                                                                                                                                  
    <!-- Optional reason popup before unlocking the current user. -->                                                                                                                                                                                          
    <Dialog id="userDetailUnlockReasonDialog" title="{i18n>unlockReasonTitle}" contentWidth="28rem">                                                                                                                                                           
        <content>                                                                                                                                                                                                                                              
            <VBox id="userDetailUnlockReasonContent" class="sapUiSmallMargin">                                                                                                                                                                                 
                <Label id="userDetailUnlockReasonLabel" text="{i18n>lockReasonLabel}" labelFor="userDetailUnlockReasonTextArea" />                                                                                                                             
                <TextArea id="userDetailUnlockReasonTextArea" width="100%" rows="4" growing="true" growingMaxLines="6" placeholder="{i18n>unlockReasonPlaceholder}" />                                                                                         
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="confirmUnlockCurrentUserButton" text="{i18n>confirmUnlock}" type="Accept" press=".onConfirmUnlockCurrentUser" />                                                                                                                       
        </beginButton>                                                                                                                                                                                                                                         
        <endButton>                                                                                                                                                                                                                                            
            <Button id="cancelUnlockCurrentUserButton" text="{i18n>cancel}" press=".onCancelUnlockCurrentUser" />                                                                                                                                              
        </endButton>                                                                                                                                                                                                                                           
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               