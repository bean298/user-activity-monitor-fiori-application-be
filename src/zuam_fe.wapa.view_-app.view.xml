<mvc:View controllerName="useractivitymonitorfioriapplication.controller.App"                                                                                                                                                                                  
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:tnt="sap.tnt"                                                                                                                                                                                                                                        
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:l="sap.ui.layout" displayBlock="true">                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
    <l:DynamicSideContent id="idDSL" showSideContent="false" sideContentVisibility="ShowAboveL">                                                                                                                                                               
        <App id="idAppControl">                                                                                                                                                                                                                                
            <pages>                                                                                                                                                                                                                                            
                <Page id="idPage" showHeader="false" backgroundDesign="Transparent">                                                                                                                                                                           
                    <content>                                                                                                                                                                                                                                  
                        <tnt:ToolPage id="toolPage">                                                                                                                                                                                                           
                            <!-- App toolheader -->                                                                                                                                                                                                            
                            <tnt:header>                                                                                                                                                                                                                       
                                <tnt:ToolHeader id="idToolHeader">                                                                                                                                                                                             
                                    <Title id="idAppTitle" text="{i18n>appTitleHeader}" level="H2"/>                                                                                                                                                           
                                    <ToolbarSpacer id="idAppTS"/>                                                                                                                                                                                              
                                    <Button id="idDashboardBtn" text="{i18n>DashboardTitle}" icon="sap-icon://business-objects-experience" type="Emphasized" press=".onNavToDashboard"/>                                                                       
                                    <Button id="idAuthBtn" text="{i18n>AuthenticationNavTitle}" icon="sap-icon://key" type="Emphasized" press=".onNavToAuthentication"/>                                                                                       
                                    <Button id="idActBtn" text="{i18n>ActivityTitle}" icon="sap-icon://activity-items" type="Emphasized" press=".onNavToActivity"/>                                                                                            
                                    <Button id="idUserBtn" text="{i18n>UserTitle}" icon="sap-icon://employee" type="Emphasized" press=".onNavToUser"/>                                                                                                         
                                    <Button id="idHistoryBtn" text="{i18n>HistoryTitle}" icon="sap-icon://history" type="Emphasized" press=".onNavToHistory"/>                                                                                                 
                                </tnt:ToolHeader>                                                                                                                                                                                                              
                            </tnt:header>                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                            <!-- Main Content -->                                                                                                                                                                                                              
                            <tnt:mainContents>                                                                                                                                                                                                                 
                                <App id="MainContainer" defaultTransitionName="slide" backgroundColor="white" backgroundOpacity="0.5"/>                                                                                                                        
                            </tnt:mainContents>                                                                                                                                                                                                                
                        </tnt:ToolPage>                                                                                                                                                                                                                        
                    </content>                                                                                                                                                                                                                                 
                </Page>                                                                                                                                                                                                                                        
            </pages>                                                                                                                                                                                                                                           
        </App>                                                                                                                                                                                                                                                 
    </l:DynamicSideContent>                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               