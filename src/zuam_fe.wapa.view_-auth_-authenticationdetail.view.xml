<mvc:View xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                          
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:ui="sap.ui.table"                                                                                                                                                                                                                                    
    displayBlock="true"                                                                                                                                                                                                                                        
    controllerName="useractivitymonitorfioriapplication.controller.auth.AuthenticationDetail">                                                                                                                                                                 
    <Page id="AuthenticationDetail" title="{i18n>authDetailTitle}" class="sapUiResponsiveContentPadding sapUiLargeMarginBottom">                                                                                                                               
        <content>                                                                                                                                                                                                                                              
            <VBox id="detailContent" class="sapUiSmallMarginBottom" renderType="Bare">                                                                                                                                                                         
                <!-- HEADER -->                                                                                                                                                                                                                                
                <ObjectHeader id="sessionHeader" responsive="true" fullScreenOptimized="true" icon="sap-icon://employee" title="{detailData>/Username}" intro="{detailData>/SessionId}" class="sapUiSmallMarginBottom">                                        
                    <attributes>                                                                                                                                                                                                                               
                        <ObjectAttribute id="attrEvent" title="{i18n>eventId}" text="{detailData>/EventId}" />                                                                                                                                                 
                        <ObjectAttribute id="attrClient" title="{i18n>client}" text="{detailData>/UserClient}" />                                                                                                                                              
                        <ObjectAttribute id="attrSystem" title="{i18n>system}" text="{detailData>/SystemId}" />                                                                                                                                                
                        <ObjectAttribute id="attrTerminal" title="{i18n>terminalId}" text="{detailData>/TerminalId}" />                                                                                                                                        
                    </attributes>                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                    <statuses>                                                                                                                                                                                                                                 
                        <ObjectStatus id="statusLoginResult" title="{i18n>loginResult}" text="{detailData>/LoginResult}" icon="{path: 'detailData>/LoginResult', formatter: '.formatter.formatLoginResultIcon'}" state="{path: 'detailData>/LoginResult', form+
atter: '.formatter.formatLoginResultState'}" />                                                                                                                                                                                                                
                        <ObjectStatus id="statusMailSent" text="{= ${detailData>/MailSent} ? 'Mail Sent' : 'Mail Not Sent' }" icon="{= ${detailData>/MailSent} ? 'sap-icon://email-read' : 'sap-icon://email' }" state="{= ${detailData>/MailSent} ? 'Success'+
 : 'None' }" />                                                                                                                                                                                                                                                
                    </statuses>                                                                                                                                                                                                                                
                </ObjectHeader>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <!-- SESSION INFORMATION -->                                                                                                                                                                                                                   
                <Panel id="sessionPanel" headerText="{i18n>sessionInfoTitle}" class="sapUiSmallMarginBottom">                                                                                                                                                  
                    <content>                                                                                                                                                                                                                                  
                        <VBox id="sessionInfoBox" renderType="Bare">                                                                                                                                                                                           
                            <HBox id="dateTimeRow" wrap="Wrap" renderType="Bare">                                                                                                                                                                              
                                <VBox id="loginDateBox" width="14rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">                                                                                                                                      
                                    <Label id="labelLoginDateDetail" text="{i18n>loginDate}" />                                                                                                                                                                
                                    <Text id="textLoginDateDetail" text="{path: 'detailData>/LoginDate', formatter: '.formatter.formatISODate'}" />                                                                                                            
                                </VBox>                                                                                                                                                                                                                        
                                <VBox id="loginTimeBox" width="14rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">                                                                                                                                      
                                    <Label id="labelLoginTimeDetail" text="{i18n>loginTime}" />                                                                                                                                                                
                                    <Text id="textLoginTimeDetail" text="{detailData>/LoginTime}" />                                                                                                                                                           
                                </VBox>                                                                                                                                                                                                                        
                                <VBox id="logoutDateBox" width="14rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">                                                                                                                                     
                                    <Label id="labelLogoutDateDetail" text="{i18n>logoutDate}" />                                                                                                                                                              
                                    <Text id="textLogoutDateDetail" text="{path: 'detailData>/LogoutDate', formatter: '.formatter.formatISODate'}" />                                                                                                          
                                </VBox>                                                                                                                                                                                                                        
                                <VBox id="logoutTimeBox" width="14rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">                                                                                                                                     
                                    <Label id="labelLogoutTimeDetail" text="{i18n>logoutTime}" />                                                                                                                                                              
                                    <Text id="textLogoutTimeDetail" text="{path: 'detailData>/LogoutTime', formatter: '.formatter.formatLogoutTime'}" />                                                                                                       
                                </VBox>                                                                                                                                                                                                                        
                                <VBox id="createdBox" width="14rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">                                                                                                                                        
                                    <Label id="labelCreatedDetail" text="{i18n>createOn}" />                                                                                                                                                                   
                                    <Text id="textCreatedDetail" text="{path: 'detailData>/CreateOn', formatter: '.formatter.formatISODate'}" />                                                                                                               
                                </VBox>                                                                                                                                                                                                                        
                            </HBox>                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                            <VBox id="messageBox" class="sapUiTinyMarginTop">                                                                                                                                                                                  
                                <Label id="labelLoginMessageDetail" text="{i18n>loginMessage}" />                                                                                                                                                              
                                <MessageStrip id="loginMessageStrip" text="{detailData>/LoginMessage}" type="{path: 'detailData>/LoginResult', formatter: '.formatter.formatLoginResultState'}" showIcon="true" class="sapUiTinyMarginTop" />                  
                            </VBox>                                                                                                                                                                                                                            
                        </VBox>                                                                                                                                                                                                                                
                    </content>                                                                                                                                                                                                                                 
                </Panel>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                <!-- ACTIVITY -->                                                                                                                                                                                                                              
                <ui:Table id="activityTable" rows="{view>/activityRows}" visibleRowCount="10" selectionMode="None" alternateRowColors="true" enableColumnReordering="true" noData="No activity found for this session">                                        
                    <ui:extension>                                                                                                                                                                                                                             
                        <OverflowToolbar id="activityToolbar">                                                                                                                                                                                                 
                            <Title id="activityTitle" text="{= 'Activity (' + ${view>/activityCount} + ')' }" level="H2" />                                                                                                                                    
                                                                                                                                                                                                                                                               
                            <ToolbarSpacer id="activityToolbarSpacer" />                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                            <ObjectStatus id="sessionActivityStatus" text="{detailData>/SessionId}" icon="sap-icon://chain-link" />                                                                                                                            
                        </OverflowToolbar>                                                                                                                                                                                                                     
                    </ui:extension>                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                    <ui:columns>                                                                                                                                                                                                                               
                        <!-- ACTIVITY TYPE -->                                                                                                                                                                                                                 
                        <ui:Column id="columnActivityType" width="9rem" sortProperty="ActType" filterProperty="ActType">                                                                                                                                       
                            <Label id="labelActivityType" text="{i18n>activityType}" />                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                            <ui:template>                                                                                                                                                                                                                      
                                <ObjectStatus id="cellActivityType" text="{view>ActType}" icon="{path: 'view>ActType', formatter: '.formatter.formatActivityType'}" state="{path: 'view>ActType', formatter: '.formatter.formatActivityState'}" />             
                            </ui:template>                                                                                                                                                                                                                     
                        </ui:Column>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                        <!-- TCODE - TCODE NAME -->                                                                                                                                                                                                            
                        <ui:Column id="columnTCode" width="16rem" sortProperty="Tcode" filterProperty="Tcode">                                                                                                                                                 
                            <Label id="labelTCode" text="{i18n>tCode}" />                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                            <ui:template>                                                                                                                                                                                                                      
                                <ObjectIdentifier id="cellTCode" title="{view>Tcode}" text="{view>TCodeName}" />                                                                                                                                               
                            </ui:template>                                                                                                                                                                                                                     
                        </ui:Column>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                        <!-- ACTIVITY MESSAGE -->                                                                                                                                                                                                              
                        <ui:Column id="columnActivityMessage" width="24rem">                                                                                                                                                                                   
                            <Label id="labelActivityMessage" text="{i18n>activityMessage}" />                                                                                                                                                                  
                                                                                                                                                                                                                                                               
                            <ui:template>                                                                                                                                                                                                                      
                                <Text id="cellActivityMessage" text="{view>MessageText}" wrapping="false" tooltip="{view>MessageText}" />                                                                                                                      
                            </ui:template>                                                                                                                                                                                                                     
                        </ui:Column>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                        <!-- ACTIVITY DATE -->                                                                                                                                                                                                                 
                        <ui:Column id="columnActivityDate" width="9rem" sortProperty="ActDate">                                                                                                                                                                
                            <Label id="labelActivityDate" text="{i18n>activityDate}" />                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                            <ui:template>                                                                                                                                                                                                                      
                                <Text id="cellActivityDate" text="{path: 'view>ActDate', formatter: '.formatter.formatISODate'}" />                                                                                                                            
                            </ui:template>                                                                                                                                                                                                                     
                        </ui:Column>                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
                        <!-- ACTIVITY TIME -->                                                                                                                                                                                                                 
                        <ui:Column id="columnActivityTime" width="8rem" sortProperty="ActTims">                                                                                                                                                                
                            <Label id="labelActivityTime" text="{i18n>activityTime}" />                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                            <ui:template>                                                                                                                                                                                                                      
                                <Text id="cellActivityTime" text="{view>ActTims}" />                                                                                                                                                                           
                            </ui:template>                                                                                                                                                                                                                     
                        </ui:Column>                                                                                                                                                                                                                           
                    </ui:columns>                                                                                                                                                                                                                              
                </ui:Table>                                                                                                                                                                                                                                    
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                               
        <footer>                                                                                                                                                                                                                                               
            <OverflowToolbar id="authDetailActivityPaginationToolbar" class="sapUiSmallMarginBottom">                                                                                                                                                          
                <ToolbarSpacer id="authDetailActivityPaginationSpacer" />                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                <Label id="authDetailActivityPageSizeLabel" text="{i18n>rowsPerPage}" />                                                                                                                                                                       
                <Select id="authDetailActivityPageSizeSelect" width="5rem" selectedKey="{view>/pageSize}" change="onChangePageSize" class="sapUiTinyMarginEnd">                                                                                                
                    <core:Item id="authDetailActivityPageSize10" key="10" text="10" />                                                                                                                                                                         
                    <core:Item id="authDetailActivityPageSize20" key="20" text="20" />                                                                                                                                                                         
                </Select>                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
                <Button id="authDetailActivityFirstPageBtn" icon="sap-icon://media-rewind" type="Transparent" tooltip="{i18n>firstPage}" enabled="{view>/canGoPrevious}" press="onFirstPage" />                                                                
                <Button id="authDetailActivityPreviousPageBtn" icon="sap-icon://navigation-left-arrow" type="Transparent" tooltip="{i18n>previousPage}" enabled="{view>/canGoPrevious}" press="onPreviousPage" />                                              
                                                                                                                                                                                                                                                               
                <Text id="authDetailActivityPageInfoText" text="{= ${i18n>page} + ' ' + ${view>/currentPage} + ' / ' + ${view>/totalPages} }" class="sapUiTinyMarginBeginEnd" />                                                                               
                                                                                                                                                                                                                                                               
                <Button id="authDetailActivityNextPageBtn" icon="sap-icon://navigation-right-arrow" type="Transparent" tooltip="{i18n>nextPage}" enabled="{view>/canGoNext}" press="onNextPage" />                                                             
                <Button id="authDetailActivityLastPageBtn" icon="sap-icon://media-forward" type="Transparent" tooltip="{i18n>lastPage}" enabled="{view>/canGoNext}" press="onLastPage" />                                                                      
                                                                                                                                                                                                                                                               
                <ToolbarSeparator id="authDetailActivityPaginationSeparator" />                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <Text id="authDetailActivityRecordRangeText" text="{= ${i18n>showingRecords} + ' ' + ${view>/displayFrom} + ' - ' + ${view>/displayTo} + ' ' + ${i18n>ofRecords} + ' ' + ${view>/activityCount} }" />                                          
            </OverflowToolbar>                                                                                                                                                                                                                                 
        </footer>                                                                                                                                                                                                                                              
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               